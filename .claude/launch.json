{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8765", "--bind", "127.0.0.1", "--directory", "frontend"],
      "port": 8765
    },
    {
      "name": "dev",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["scripts/dev_proxy.py"],
      "port": 8765
    },
    {
      "name": "dev-nervous",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["scripts/dev_proxy.py"],
      "port": 8766,
      "env": { "DEV_PROXY_PORT": "8766" }
    }
  ]
}
